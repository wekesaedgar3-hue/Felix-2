# Backend server port
PORT=4000
# Optional backend URL override used by the frontend proxy
BACKEND_URL=http://127.0.0.1:4000
# Postgres connection string
PG_CONN_STRING=postgres://postgres:postgres@localhost:5432/felix

# JWT secret
JWT_SECRET=supersecretchangeit

# Safaricom Daraja credentials (sandbox)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_STK_PASSWORD=
MPESA_CALLBACK_URL=http://your-domain.com/api/mpesa/callback
MPESA_CALLBACK_SECRET=optional_shared_secret_for_callbacks
